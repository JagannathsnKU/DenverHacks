{
  "name": "ai-agent-trust-layer",
  "version": "1.0.0",
  "description": "Production-grade AI Agent Trust & Payment Layer for ETHDenver 2026",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "tsx dist/index.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "contracts:build": "hardhat compile",
    "contracts:deploy:base": "hardhat run scripts/deploy.ts --network baseSepolia",
    "contracts:deploy:kite": "hardhat run scripts/deploy.ts --network kiteTestnet",
    "contracts:deploy:zg": "hardhat run scripts/deploy.ts --network zgTestnet",
    "contracts:verify": "hardhat verify",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@hashgraph/sdk": "^2.x",
    "@prisma/client": "^5.x",
    "axios": "^1.x",
    "bullmq": "^5.x",
    "dotenv": "^17.3.1",
    "ethers": "^6.x",
    "express": "^5.0.0",
    "ioredis": "^5.x",
    "pino": "^9.x",
    "pino-http": "^10.x",
    "siwe": "^2.x",
    "swagger-parser": "^10.x",
    "uuid": "^9.x",
    "viem": "^2.x",
    "zod": "^3.x"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-verify": "^2.x",
    "@nomicfoundation/hardhat-viem": "^2.x",
    "@types/express": "^5.x",
    "@types/node": "^20.x",
    "@types/uuid": "^9.x",
    "hardhat": "^2.x",
    "prisma": "^5.x",
    "solc": "^0.8.24",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.x",
    "typescript": "^5.x",
    "vitest": "^1.x"
  }
}
